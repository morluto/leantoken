# LeanToken environment variables
#
# This file documents all environment variables that affect LeanToken behavior.
# Copy this file to .env and customize values for local development.
# The .env file is gitignored and should never be committed.

# Log level filter (default: warn)
# Valid levels: trace, debug, info, warn, error
# RUST_LOG=leantoken=debug,info

# Database path override (default: ~/.cache/leantoken/leantoken.db)
# LEANTOKEN_DB_PATH=/custom/path/to/leantoken.db

# Indexing parallelism (default: number of CPU cores)
# LEANTOKEN_MAX_INDEX_WORKERS=4

# Watcher debounce duration in milliseconds (default: 500)
# LEANTOKEN_WATCHER_DEBOUNCE_MS=500
