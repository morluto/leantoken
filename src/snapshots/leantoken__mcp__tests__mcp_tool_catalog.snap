---
source: src/mcp.rs
assertion_line: 1535
expression: tools
---
[
  {
    "name": "leantoken_context",
    "description": "DEFAULT FIRST CALL for broad coding, debugging, review, and architecture tasks. Returns the most relevant repository evidence within a strict token budget instead of manually combining search and whole-file reads. Reuse receipt fragment_hashes as known_hashes. Example: {\"task\":\"Audit MCP tool discovery\"}.",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "base_revision": {
          "default": null,
          "description": "Base revision for diff-scoped context.",
          "maxLength": 256,
          "type": [
            "string",
            "null"
          ]
        },
        "changed_paths": {
          "default": [],
          "description": "Changed paths for diff-scoped context.",
          "items": {
            "maxLength": 4096,
            "type": "string"
          },
          "maxItems": 512,
          "type": "array"
        },
        "consistency": {
          "default": "committed",
          "description": "Use `working_tree` after edits; otherwise `committed`.",
          "enum": [
            "committed",
            "working_tree"
          ],
          "type": "string"
        },
        "exclude_paths": {
          "default": [],
          "description": "Exclude matching repository paths.",
          "items": {
            "maxLength": 4096,
            "type": "string"
          },
          "maxItems": 256,
          "type": "array"
        },
        "focus_paths": {
          "default": [],
          "description": "Boost matching paths without filtering other candidates.",
          "items": {
            "maxLength": 4096,
            "type": "string"
          },
          "maxItems": 256,
          "type": "array"
        },
        "focus_symbols": {
          "default": [],
          "description": "Boost candidates for these exact symbol names.",
          "items": {
            "maxLength": 4096,
            "type": "string"
          },
          "maxItems": 256,
          "type": "array"
        },
        "known_hashes": {
          "default": [],
          "description": "Fragment hashes already held by the caller and not to resend.",
          "items": {
            "maxLength": 128,
            "type": "string"
          },
          "maxItems": 256,
          "type": "array"
        },
        "prior_repository_generation": {
          "default": null,
          "description": "Earlier generation used to boost files indexed since that response.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "task": {
          "description": "Natural-language coding task; include known identifiers and constraints.",
          "maxLength": 65536,
          "minLength": 3,
          "type": "string"
        },
        "token_budget": {
          "default": 3000,
          "description": "Maximum source tokens across selected fragments (default 3000, maximum 32000).",
          "format": "uint",
          "maximum": 32000,
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "task"
      ],
      "type": "object"
    }
  },
  {
    "name": "leantoken_files",
    "description": "Preferred repository path discovery instead of find, ls, or glob. Use tree for hierarchy, find for fuzzy filenames, and glob for path patterns; returns paths, not source. Example: {\"operation\":{\"kind\":\"find\",\"query\":\"mcp\"}}.",
    "inputSchema": {
      "$defs": {
        "FilesMcpOperation": {
          "oneOf": [
            {
              "additionalProperties": false,
              "description": "Return a compact hierarchy, optionally below one repository-relative directory.",
              "properties": {
                "depth": {
                  "default": null,
                  "description": "Maximum hierarchy depth below `path`.",
                  "format": "uint",
                  "minimum": 0,
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "kind": {
                  "const": "tree",
                  "type": "string"
                },
                "path": {
                  "default": null,
                  "description": "Optional repository-relative directory.",
                  "maxLength": 4096,
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "required": [
                "kind"
              ],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "description": "Fuzzy-match repository paths and basenames.",
              "properties": {
                "kind": {
                  "const": "find",
                  "type": "string"
                },
                "query": {
                  "description": "Non-empty fuzzy filename or path query.",
                  "maxLength": 65536,
                  "minLength": 1,
                  "type": "string"
                }
              },
              "required": [
                "kind",
                "query"
              ],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "description": "Match indexed repository paths with a glob.",
              "properties": {
                "kind": {
                  "const": "glob",
                  "type": "string"
                },
                "pattern": {
                  "description": "Non-empty glob pattern such as `src/**/*.rs`.",
                  "maxLength": 4096,
                  "minLength": 1,
                  "type": "string"
                }
              },
              "required": [
                "kind",
                "pattern"
              ],
              "type": "object"
            }
          ]
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "consistency": {
          "default": "committed",
          "description": "Use `working_tree` after edits; otherwise `committed`.",
          "enum": [
            "committed",
            "working_tree"
          ],
          "type": "string"
        },
        "cursor": {
          "default": null,
          "description": "Cursor returned by the same operation and repository generation.",
          "maxLength": 4096,
          "type": [
            "string",
            "null"
          ]
        },
        "max_results": {
          "default": 20,
          "description": "Maximum entries to return (default 20, maximum 100).",
          "format": "uint",
          "maximum": 100,
          "minimum": 1,
          "type": "integer"
        },
        "operation": {
          "$ref": "#/$defs/FilesMcpOperation",
          "description": "Path operation and its operation-specific arguments."
        }
      },
      "required": [
        "operation"
      ],
      "type": "object"
    }
  },
  {
    "name": "leantoken_outline",
    "description": "Inspect file structure without reading whole source files. Prefer this when the file is known but the relevant symbol or range is not; then use leantoken_read. Example: {\"paths\":[\"src/mcp.rs\"]}.",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "consistency": {
          "default": "committed",
          "description": "Use `working_tree` after edits; otherwise `committed`.",
          "enum": [
            "committed",
            "working_tree"
          ],
          "type": "string"
        },
        "max_results": {
          "default": 20,
          "description": "Maximum definitions and imports to return (default 20, maximum 100).",
          "format": "uint",
          "maximum": 100,
          "minimum": 1,
          "type": "integer"
        },
        "max_tokens": {
          "default": 8000,
          "description": "Maximum signature and import tokens (default 8000, maximum 32000).",
          "format": "uint",
          "maximum": 32000,
          "minimum": 1,
          "type": "integer"
        },
        "paths": {
          "description": "One to 256 repository-relative source files to outline.",
          "items": {
            "maxLength": 4096,
            "type": "string"
          },
          "maxItems": 256,
          "minItems": 1,
          "type": "array"
        },
        "symbol_kind": {
          "default": null,
          "description": "Keep definitions of this exact syntax kind.",
          "maxLength": 4096,
          "type": [
            "string",
            "null"
          ]
        },
        "symbol_name": {
          "default": null,
          "description": "Keep definitions whose names contain this value.",
          "maxLength": 4096,
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "paths"
      ],
      "type": "object"
    }
  },
  {
    "name": "leantoken_read",
    "description": "Preferred exact source reader instead of cat, head, or sed. Keep path as a file path; put the owner separately in target. Exact target shapes are {\"kind\":\"symbol\",\"name\":\"LeanTokenMcp\"} and {\"kind\":\"lines\",\"start\":120,\"end\":160}. Reuse content_hash as expected_hash to suppress unchanged source. Example: {\"path\":\"src/mcp.rs\",\"target\":{\"kind\":\"symbol\",\"name\":\"LeanTokenMcp\"}}.",
    "inputSchema": {
      "$defs": {
        "ReadMcpTarget": {
          "oneOf": [
            {
              "additionalProperties": false,
              "description": "Read one indexed symbol definition.",
              "properties": {
                "kind": {
                  "const": "symbol",
                  "type": "string"
                },
                "name": {
                  "description": "Exact indexed symbol name.",
                  "maxLength": 4096,
                  "minLength": 1,
                  "type": "string"
                }
              },
              "required": [
                "kind",
                "name"
              ],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "description": "Read one inclusive one-based line range.",
              "properties": {
                "end": {
                  "description": "Last one-based line; must be at least `start`.",
                  "format": "uint",
                  "minimum": 1,
                  "type": "integer"
                },
                "kind": {
                  "const": "lines",
                  "type": "string"
                },
                "start": {
                  "description": "First one-based line.",
                  "format": "uint",
                  "minimum": 1,
                  "type": "integer"
                }
              },
              "required": [
                "kind",
                "start",
                "end"
              ],
              "type": "object"
            }
          ]
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "consistency": {
          "default": "committed",
          "description": "Use `working_tree` after edits; otherwise `committed`.",
          "enum": [
            "committed",
            "working_tree"
          ],
          "type": "string"
        },
        "expected_hash": {
          "default": null,
          "description": "Hash from the same prior target; matching content returns `not_modified`.",
          "maxLength": 128,
          "type": [
            "string",
            "null"
          ]
        },
        "max_tokens": {
          "default": 8000,
          "description": "Maximum source tokens to return (default 8000, maximum 32000).",
          "format": "uint",
          "maximum": 32000,
          "minimum": 1,
          "type": "integer"
        },
        "path": {
          "description": "Repository-relative UTF-8 source file.",
          "maxLength": 4096,
          "minLength": 1,
          "type": "string"
        },
        "target": {
          "$ref": "#/$defs/ReadMcpTarget",
          "description": "Exact symbol or inclusive line range to read."
        }
      },
      "required": [
        "path",
        "target"
      ],
      "type": "object"
    }
  },
  {
    "name": "leantoken_savings",
    "description": "Report cumulative repository-local estimated source-token savings. Use when asked how many tokens LeanToken saved. Example: {}.",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "type": "object"
    },
    "annotations": {
      "readOnlyHint": true,
      "openWorldHint": false
    }
  },
  {
    "name": "leantoken_search",
    "description": "Preferred indexed source search instead of grep or rg. Finds ranked symbols, references, identifiers, text, or regex matches. Text and regex hits include the narrowest enclosing_symbol when structural data is available; use that exact name or the returned line range with leantoken_read. Example: {\"query\":\"RetryableConflict\",\"mode\":\"symbol\"}.",
    "inputSchema": {
      "$defs": {
        "SearchMode": {
          "description": "Search candidate source.",
          "oneOf": [
            {
              "const": "auto",
              "description": "Combine structural and lexical candidates.",
              "type": "string"
            },
            {
              "const": "text",
              "description": "Match a literal substring.",
              "type": "string"
            },
            {
              "const": "regex",
              "description": "Verify a Rust regular expression over indexed chunks.",
              "type": "string"
            },
            {
              "const": "identifier",
              "description": "Search identifier tokens and structural names.",
              "type": "string"
            },
            {
              "const": "symbol",
              "description": "Search definitions only.",
              "type": "string"
            },
            {
              "const": "reference",
              "description": "Search syntactic references only.",
              "type": "string"
            }
          ]
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "case_sensitive": {
          "default": false,
          "description": "Preserve query case when matching.",
          "type": "boolean"
        },
        "consistency": {
          "default": "committed",
          "description": "Use `working_tree` after edits; otherwise `committed`.",
          "enum": [
            "committed",
            "working_tree"
          ],
          "type": "string"
        },
        "context_lines": {
          "default": 2,
          "description": "Lines before and after each match (default 2, maximum 20).",
          "format": "uint",
          "maximum": 20,
          "minimum": 0,
          "type": "integer"
        },
        "cursor": {
          "default": null,
          "description": "Cursor returned by the same search and repository generation.",
          "maxLength": 4096,
          "type": [
            "string",
            "null"
          ]
        },
        "exclude_paths": {
          "default": [],
          "description": "Exclude matching repository paths.",
          "items": {
            "maxLength": 4096,
            "type": "string"
          },
          "maxItems": 256,
          "type": "array"
        },
        "focus_paths": {
          "default": [],
          "description": "Boost matching paths without filtering other results.",
          "items": {
            "maxLength": 4096,
            "type": "string"
          },
          "maxItems": 256,
          "type": "array"
        },
        "include_paths": {
          "default": [],
          "description": "Include only matching repository paths.",
          "items": {
            "maxLength": 4096,
            "type": "string"
          },
          "maxItems": 256,
          "type": "array"
        },
        "max_results": {
          "default": 20,
          "description": "Maximum hits to return (default 20, maximum 100).",
          "format": "uint",
          "maximum": 100,
          "minimum": 1,
          "type": "integer"
        },
        "max_tokens": {
          "default": 8000,
          "description": "Maximum source tokens across excerpts (default 8000, maximum 32000).",
          "format": "uint",
          "maximum": 32000,
          "minimum": 1,
          "type": "integer"
        },
        "mode": {
          "$ref": "#/$defs/SearchMode",
          "default": "auto",
          "description": "Candidate source to search (default `auto`)."
        },
        "query": {
          "description": "Non-empty text, identifier, symbol, or Rust regular expression to find.",
          "maxLength": 65536,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
