---
source: src/mcp.rs
expression: tools
---
[
  {
    "name": "leantoken_context",
    "description": "Retrieve ranked task context within a token budget.",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "exclude_paths": {
          "default": [],
          "description": "Exclude matching repository paths.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "focus_paths": {
          "default": [],
          "description": "Boost matching paths without filtering other candidates.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "focus_symbols": {
          "default": [],
          "description": "Boost candidates for these exact symbol names.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "known_hashes": {
          "default": [],
          "description": "Fragment hashes already held by the caller and not to resend.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "prior_repository_generation": {
          "default": null,
          "description": "Earlier generation used to boost files indexed since that response.",
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "task": {
          "description": "Natural-language coding task used to retrieve evidence.",
          "type": "string"
        },
        "token_budget": {
          "description": "Maximum source tokens across selected fragments.",
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "task",
        "token_budget"
      ],
      "type": "object"
    },
    "outputSchema": {
      "$defs": {
        "ContextFragment": {
          "properties": {
            "content": {
              "type": "string"
            },
            "content_hash": {
              "type": "string"
            },
            "end_line": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "path": {
              "type": "string"
            },
            "reason": {
              "type": "string"
            },
            "representation": {
              "type": "string"
            },
            "score": {
              "format": "double",
              "type": "number"
            },
            "start_line": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "token_count": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "path",
            "start_line",
            "end_line",
            "representation",
            "content",
            "content_hash",
            "score",
            "reason",
            "token_count"
          ],
          "type": "object"
        },
        "EvidenceIdentity": {
          "properties": {
            "content_hash": {
              "type": "string"
            },
            "end_line": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "path": {
              "type": "string"
            },
            "start_line": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "path",
            "start_line",
            "end_line",
            "content_hash"
          ],
          "type": "object"
        },
        "EvidenceReceipt": {
          "properties": {
            "fragments": {
              "items": {
                "$ref": "#/$defs/EvidenceIdentity"
              },
              "type": "array"
            },
            "repository_generation": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "task_fingerprint": {
              "type": "string"
            }
          },
          "required": [
            "task_fingerprint",
            "repository_generation",
            "fragments"
          ],
          "type": "object"
        },
        "Freshness": {
          "description": "State of the committed index while a response is produced.",
          "oneOf": [
            {
              "const": "current",
              "description": "No reconciliation is active.",
              "type": "string"
            },
            {
              "const": "reconciling",
              "description": "A query used the last committed generation during reconciliation.",
              "type": "string"
            }
          ]
        },
        "OmittedCandidate": {
          "properties": {
            "end_line": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "path": {
              "type": "string"
            },
            "reason": {
              "type": "string"
            },
            "start_line": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "path",
            "start_line",
            "end_line",
            "reason"
          ],
          "type": "object"
        },
        "ResponseMeta": {
          "properties": {
            "emitted_tokens": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "freshness": {
              "$ref": "#/$defs/Freshness"
            },
            "next_cursor": {
              "type": [
                "string",
                "null"
              ]
            },
            "repository_generation": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "token_count_exact": {
              "type": "boolean"
            }
          },
          "required": [
            "repository_generation",
            "freshness",
            "emitted_tokens",
            "token_count_exact"
          ],
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "fragments": {
          "items": {
            "$ref": "#/$defs/ContextFragment"
          },
          "type": "array"
        },
        "meta": {
          "$ref": "#/$defs/ResponseMeta"
        },
        "omitted": {
          "items": {
            "$ref": "#/$defs/OmittedCandidate"
          },
          "type": "array"
        },
        "receipt": {
          "$ref": "#/$defs/EvidenceReceipt"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "fragments",
        "receipt",
        "omitted",
        "warnings",
        "meta"
      ],
      "type": "object"
    }
  },
  {
    "name": "leantoken_files",
    "description": "List, find, or glob repository files.",
    "inputSchema": {
      "$defs": {
        "FileOperation": {
          "description": "Repository path-discovery operation.",
          "oneOf": [
            {
              "const": "tree",
              "description": "Return a compact hierarchy.",
              "type": "string"
            },
            {
              "const": "find",
              "description": "Fuzzy-match paths and basenames.",
              "type": "string"
            },
            {
              "const": "glob",
              "description": "Match indexed paths with a glob.",
              "type": "string"
            }
          ]
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "cursor": {
          "default": null,
          "description": "Cursor returned by an earlier response from the same generation.",
          "type": [
            "string",
            "null"
          ]
        },
        "depth": {
          "default": null,
          "description": "Maximum hierarchy depth below `path` for `tree`.",
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "max_results": {
          "default": null,
          "description": "Maximum entries to return.",
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "operation": {
          "$ref": "#/$defs/FileOperation",
          "description": "Discovery operation to perform."
        },
        "path": {
          "default": null,
          "description": "Optional repository-relative tree root.",
          "type": [
            "string",
            "null"
          ]
        },
        "pattern": {
          "default": null,
          "description": "Glob pattern used by `glob`.",
          "type": [
            "string",
            "null"
          ]
        },
        "query": {
          "default": null,
          "description": "Fuzzy path query used by `find`.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "operation"
      ],
      "type": "object"
    },
    "outputSchema": {
      "$defs": {
        "FileEntry": {
          "properties": {
            "kind": {
              "$ref": "#/$defs/FileEntryKind"
            },
            "language": {
              "type": [
                "string",
                "null"
              ]
            },
            "path": {
              "type": "string"
            },
            "score": {
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "size_bytes": {
              "format": "uint64",
              "minimum": 0,
              "type": [
                "integer",
                "null"
              ]
            }
          },
          "required": [
            "path",
            "kind"
          ],
          "type": "object"
        },
        "FileEntryKind": {
          "enum": [
            "file",
            "directory"
          ],
          "type": "string"
        },
        "Freshness": {
          "description": "State of the committed index while a response is produced.",
          "oneOf": [
            {
              "const": "current",
              "description": "No reconciliation is active.",
              "type": "string"
            },
            {
              "const": "reconciling",
              "description": "A query used the last committed generation during reconciliation.",
              "type": "string"
            }
          ]
        },
        "ResponseMeta": {
          "properties": {
            "emitted_tokens": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "freshness": {
              "$ref": "#/$defs/Freshness"
            },
            "next_cursor": {
              "type": [
                "string",
                "null"
              ]
            },
            "repository_generation": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "token_count_exact": {
              "type": "boolean"
            }
          },
          "required": [
            "repository_generation",
            "freshness",
            "emitted_tokens",
            "token_count_exact"
          ],
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "entries": {
          "items": {
            "$ref": "#/$defs/FileEntry"
          },
          "type": "array"
        },
        "meta": {
          "$ref": "#/$defs/ResponseMeta"
        }
      },
      "required": [
        "entries",
        "meta"
      ],
      "type": "object"
    }
  },
  {
    "name": "leantoken_outline",
    "description": "Return structural outline for one or more files.",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "max_results": {
          "default": null,
          "description": "Maximum definitions and imports to return.",
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "max_tokens": {
          "default": null,
          "description": "Maximum tokens across signatures and import targets.",
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "paths": {
          "description": "Repository-relative files to outline.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "symbol_kind": {
          "default": null,
          "description": "Keep definitions of this exact syntax kind.",
          "type": [
            "string",
            "null"
          ]
        },
        "symbol_name": {
          "default": null,
          "description": "Keep definitions whose names contain this value.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "paths"
      ],
      "type": "object"
    },
    "outputSchema": {
      "$defs": {
        "Freshness": {
          "description": "State of the committed index while a response is produced.",
          "oneOf": [
            {
              "const": "current",
              "description": "No reconciliation is active.",
              "type": "string"
            },
            {
              "const": "reconciling",
              "description": "A query used the last committed generation during reconciliation.",
              "type": "string"
            }
          ]
        },
        "Import": {
          "properties": {
            "line": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "raw_target": {
              "type": "string"
            },
            "resolved_path": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "raw_target",
            "line"
          ],
          "type": "object"
        },
        "OutlineFile": {
          "properties": {
            "imports": {
              "items": {
                "$ref": "#/$defs/Import"
              },
              "type": "array"
            },
            "language": {
              "type": [
                "string",
                "null"
              ]
            },
            "path": {
              "type": "string"
            },
            "structurally_complete": {
              "type": "boolean"
            },
            "symbols": {
              "items": {
                "$ref": "#/$defs/Symbol"
              },
              "type": "array"
            }
          },
          "required": [
            "path",
            "structurally_complete",
            "symbols",
            "imports"
          ],
          "type": "object"
        },
        "ResponseMeta": {
          "properties": {
            "emitted_tokens": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "freshness": {
              "$ref": "#/$defs/Freshness"
            },
            "next_cursor": {
              "type": [
                "string",
                "null"
              ]
            },
            "repository_generation": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "token_count_exact": {
              "type": "boolean"
            }
          },
          "required": [
            "repository_generation",
            "freshness",
            "emitted_tokens",
            "token_count_exact"
          ],
          "type": "object"
        },
        "Symbol": {
          "properties": {
            "end_byte": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "end_line": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "kind": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "parent": {
              "type": [
                "string",
                "null"
              ]
            },
            "signature": {
              "type": [
                "string",
                "null"
              ]
            },
            "start_byte": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "start_line": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "name",
            "kind",
            "start_line",
            "end_line",
            "start_byte",
            "end_byte"
          ],
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "files": {
          "items": {
            "$ref": "#/$defs/OutlineFile"
          },
          "type": "array"
        },
        "meta": {
          "$ref": "#/$defs/ResponseMeta"
        }
      },
      "required": [
        "files",
        "meta"
      ],
      "type": "object"
    }
  },
  {
    "name": "leantoken_read",
    "description": "Read a bounded file range by path or symbol.",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "end_line": {
          "default": null,
          "description": "Last one-based line; defaults to the end of the file.",
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "expected_hash": {
          "default": null,
          "description": "Hash from the same prior range; matching content returns `not_modified`.",
          "type": [
            "string",
            "null"
          ]
        },
        "max_tokens": {
          "default": null,
          "description": "Maximum source tokens to return.",
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "path": {
          "description": "Repository-relative file path.",
          "type": "string"
        },
        "start_line": {
          "default": null,
          "description": "First one-based line; defaults to the start of the file.",
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "symbol": {
          "default": null,
          "description": "Indexed symbol to read; cannot be combined with line fields.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "path"
      ],
      "type": "object"
    },
    "outputSchema": {
      "$defs": {
        "Freshness": {
          "description": "State of the committed index while a response is produced.",
          "oneOf": [
            {
              "const": "current",
              "description": "No reconciliation is active.",
              "type": "string"
            },
            {
              "const": "reconciling",
              "description": "A query used the last committed generation during reconciliation.",
              "type": "string"
            }
          ]
        },
        "ReadStatus": {
          "enum": [
            "content",
            "not_modified"
          ],
          "type": "string"
        },
        "ResponseMeta": {
          "properties": {
            "emitted_tokens": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "freshness": {
              "$ref": "#/$defs/Freshness"
            },
            "next_cursor": {
              "type": [
                "string",
                "null"
              ]
            },
            "repository_generation": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "token_count_exact": {
              "type": "boolean"
            }
          },
          "required": [
            "repository_generation",
            "freshness",
            "emitted_tokens",
            "token_count_exact"
          ],
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "content": {
          "type": [
            "string",
            "null"
          ]
        },
        "content_hash": {
          "type": "string"
        },
        "end_line": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "index_stale": {
          "type": "boolean"
        },
        "indexed_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "meta": {
          "$ref": "#/$defs/ResponseMeta"
        },
        "path": {
          "type": "string"
        },
        "start_line": {
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "status": {
          "$ref": "#/$defs/ReadStatus"
        }
      },
      "required": [
        "path",
        "status",
        "start_line",
        "end_line",
        "content_hash",
        "index_stale",
        "meta"
      ],
      "type": "object"
    }
  },
  {
    "name": "leantoken_search",
    "description": "Search repository text, symbols, or references.",
    "inputSchema": {
      "$defs": {
        "SearchMode": {
          "description": "Search candidate source.",
          "oneOf": [
            {
              "const": "auto",
              "description": "Combine structural and lexical candidates.",
              "type": "string"
            },
            {
              "const": "text",
              "description": "Match a literal substring.",
              "type": "string"
            },
            {
              "const": "regex",
              "description": "Verify a Rust regular expression over indexed chunks.",
              "type": "string"
            },
            {
              "const": "identifier",
              "description": "Search identifier tokens and structural names.",
              "type": "string"
            },
            {
              "const": "symbol",
              "description": "Search definitions only.",
              "type": "string"
            },
            {
              "const": "reference",
              "description": "Search syntactic references only.",
              "type": "string"
            }
          ]
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "case_sensitive": {
          "default": false,
          "description": "Preserve query case when matching.",
          "type": "boolean"
        },
        "context_lines": {
          "default": null,
          "description": "Lines included before and after each match.",
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "cursor": {
          "default": null,
          "description": "Cursor returned by an earlier response from the same generation.",
          "type": [
            "string",
            "null"
          ]
        },
        "exclude_paths": {
          "default": [],
          "description": "Exclude matching repository paths.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "focus_paths": {
          "default": [],
          "description": "Boost matching repository paths without filtering other results.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "include_paths": {
          "default": [],
          "description": "Include only matching repository paths.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "max_results": {
          "default": null,
          "description": "Maximum hits to return.",
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "max_tokens": {
          "default": null,
          "description": "Maximum source tokens across returned excerpts.",
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "mode": {
          "$ref": "#/$defs/SearchMode",
          "default": "auto",
          "description": "Candidate source to search."
        },
        "query": {
          "description": "Text, identifier, symbol, or regular expression to find.",
          "type": "string"
        }
      },
      "required": [
        "query"
      ],
      "type": "object"
    },
    "outputSchema": {
      "$defs": {
        "Freshness": {
          "description": "State of the committed index while a response is produced.",
          "oneOf": [
            {
              "const": "current",
              "description": "No reconciliation is active.",
              "type": "string"
            },
            {
              "const": "reconciling",
              "description": "A query used the last committed generation during reconciliation.",
              "type": "string"
            }
          ]
        },
        "ReferenceRole": {
          "enum": [
            "definition",
            "reference"
          ],
          "type": "string"
        },
        "ResponseMeta": {
          "properties": {
            "emitted_tokens": {
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "freshness": {
              "$ref": "#/$defs/Freshness"
            },
            "next_cursor": {
              "type": [
                "string",
                "null"
              ]
            },
            "repository_generation": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "token_count_exact": {
              "type": "boolean"
            }
          },
          "required": [
            "repository_generation",
            "freshness",
            "emitted_tokens",
            "token_count_exact"
          ],
          "type": "object"
        },
        "SearchHit": {
          "properties": {
            "content_hash": {
